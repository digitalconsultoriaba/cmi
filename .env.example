# Plataforma de Eventos — exemplo de configuração (APENAS placeholders; nunca
# commitar valores reais). Copie para .env: `make install` faz isso.

APP_NAME="Plataforma de Eventos"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# MySQL 8 (docker compose: serviço `mysql`; use 127.0.0.1 se rodar PHP no host)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=root
DB_PASSWORD=root

# Banco de testes (usado pelo phpunit via conexão dedicada)
DB_TEST_DATABASE=app_test

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# SPA (Sanctum por cookie)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8000
FRONTEND_URL=http://localhost:5173

# Google OAuth (Socialite) — obter no Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mailpit (docker compose) — UI em http://localhost:8025
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="nao-responda@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Pagamento — drivers (fake = dev/teste; sicoob/boletos/asaas real por env)
# PIX: fake | sicoob (direto, mTLS) | boletos (microsserviço Boletos SICOOB V2)
PAYMENTS_PIX_DRIVER=fake
# Cartão: fake (token síncrono) | asaas (Checkout hospedado, spec 015)
PAYMENTS_CARD_DRIVER=fake
SICOOB_CLIENT_ID=
SICOOB_CERT_PATH=
SICOOB_CERT_KEY_PATH=
SICOOB_SANDBOX=true
SICOOB_WEBHOOK_SECRET=
CARD_WEBHOOK_SECRET=

# PIX via microsserviço Boletos SICOOB V2 (spec 015). Token real só no .env.
# Da API rodando em Docker, use host.docker.internal (não localhost).
BOLETOS_API_URL=http://host.docker.internal:18100
BOLETOS_API_TOKEN=
BOLETOS_PIX_EXPIRACAO=3600
# Webhook PIX (doc v1.1.0 §5.1): URL pública HTTPS deste app que recebe o aviso
# de pagamento. Vazio = só polling. Segredo HMAC deve ser IGUAL ao do microsserviço
# (SICOOB_PIX_NOTIFY_SECRET). Produção: https://cmi.glmees.org.br/api/webhooks/pix
BOLETOS_PIX_NOTIFY_URL=
SICOOB_PIX_NOTIFY_SECRET=

# ASAAS — Checkout de cartão (spec 015). Placeholders apenas; chave real só no .env.
ASAAS_API_KEY=
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_SECRET=
ASAAS_MAX_INSTALLMENTS=12

# Site/CMS (spec 013): provedor de tradução automática do Site. Vazio = tradução
# manual (sem provedor). Uma classe que implemente TranslationProviderContract.
SITE_TRANSLATION_PROVIDER=
